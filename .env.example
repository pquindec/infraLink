# Vercel KV — estas variables las genera Vercel automáticamente
# al conectar un KV Store a tu proyecto.
# Para desarrollo local: cópialas desde Vercel Dashboard → Storage → tu KV → .env.local

KV_REST_API_URL=https://xxxxxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KV_REST_API_READ_ONLY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Contraseña del panel de administración en /admin
ADMIN_SECRET=cambia-esta-contrasena-segura
