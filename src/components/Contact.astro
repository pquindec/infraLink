---
import WhatsAppButton from './react/WhatsAppButton.tsx';
---

<section id="contacto" class="py-24 lg:py-32 relative" style="background: linear-gradient(180deg, #0a1628 0%, #060e1f 100%);">

  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="inline-block bg-green-500/10 border border-green-500/20 text-green-300 text-sm font-semibold px-4 py-2 rounded-full mb-4">
        Contacto
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-4 leading-tight">
        Hablemos sobre su
        <span class="gradient-text block mt-1">próximo proyecto</span>
      </h2>
      <p class="text-gray-400 text-base sm:text-lg max-w-lg mx-auto leading-relaxed">
        Estamos disponibles para responder sus consultas y comenzar a trabajar en su solución tecnológica.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 items-start">

      <!-- WhatsApp card -->
      <div class="animate-on-scroll bg-gradient-to-br from-green-500/10 to-green-600/5 border border-green-500/20 rounded-3xl p-8 hover:border-green-500/40 transition-all duration-300">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center shadow-lg shadow-green-500/30">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-white">WhatsApp</h3>
            <p class="text-green-300 text-sm font-medium">Respuesta inmediata</p>
          </div>
        </div>

        <p class="text-gray-300 text-sm leading-relaxed mb-6 max-w-sm">
          Escríbenos directamente por WhatsApp y un especialista le atenderá a la brevedad para analizar sus requerimientos.
        </p>

        <!-- Phone number display -->
        <div class="bg-black/20 border border-white/10 rounded-xl px-5 py-3 mb-6 flex items-center gap-3">
          <svg class="w-4 h-4 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span class="text-white font-mono font-semibold tracking-wide">0960 089 996</span>
          <span class="ml-auto flex items-center gap-1 text-green-400 text-xs">
            <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
            Disponible
          </span>
        </div>

        <!-- Message preview -->
        <div class="bg-black/20 border border-white/5 rounded-xl p-4 mb-6">
          <p class="text-xs text-gray-500 mb-2 font-medium uppercase tracking-wider">Mensaje prellenado</p>
          <p class="text-gray-300 text-sm italic">"Hola, estoy interesado en sus servicios tecnológicos"</p>
        </div>

        <WhatsAppButton
          variant="hero"
          label="Iniciar conversación"
          client:visible
        />
      </div>

      <!-- Info cards -->
      <div class="space-y-5 animate-on-scroll" style="transition-delay: 200ms;">

        <!-- Email card -->
        <div class="bg-white/3 border border-white/8 rounded-2xl p-6 hover:border-blue-500/30 hover:bg-blue-500/5 transition-all duration-300 group">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center shadow-lg shadow-blue-500/20 flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h4 class="text-white font-semibold mb-1">Correo electrónico</h4>
              <a
                href="mailto:asespinoza97@outlook.com"
                class="text-blue-400 hover:text-blue-300 text-sm font-medium transition-colors break-all"
              >
                asespinoza97@outlook.com
              </a>
            </div>
          </div>
        </div>

        <!-- Services quick list -->
        <div class="bg-white/3 border border-white/8 rounded-2xl p-6">
          <h4 class="text-white font-semibold mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            ¿En qué podemos ayudarle?
          </h4>
          <div class="space-y-2">
            {[
              'Infraestructura tecnológica',
              'Soporte técnico especializado',
              'Redes y telecomunicaciones',
              'Seguridad electrónica CCTV',
              'Soluciones WiFi empresariales',
            ].map(item => (
              <a
                href={`https://wa.me/593960089996?text=Hola%2C%20me%20interesa%20el%20servicio%20de%20${encodeURIComponent(item)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-between gap-3 text-gray-400 hover:text-white text-sm py-2 px-3 rounded-lg hover:bg-white/5 transition-all duration-200 group/item"
              >
                <span class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-400 flex-shrink-0"></span>
                  {item}
                </span>
                <svg class="w-3.5 h-3.5 opacity-0 group-hover/item:opacity-100 transition-opacity flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            ))}
          </div>
        </div>

        <!-- Team card -->
        <div class="bg-gradient-to-br from-brand-accent/10 to-transparent border border-blue-500/20 rounded-2xl p-5">
          <p class="text-xs text-blue-300 uppercase tracking-wider font-semibold mb-3 flex items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Equipo InfraLink Networks
          </p>
          <div class="space-y-2.5">
            {[
              { name: 'Antony S. Espinoza O.',  initials: 'AE', color: 'from-blue-500 to-blue-700',     title: 'Ing. de Sistemas' },
              { name: 'Paúl A. Quinde C.',       initials: 'PQ', color: 'from-indigo-500 to-indigo-700', title: 'Ing. de Sistemas' },
              { name: 'Wilmer E. Miñan P.',      initials: 'WM', color: 'from-cyan-500 to-cyan-700',     title: 'Ing. de Sistemas' },
              { name: 'Roberto C. Franco H.',    initials: 'RF', color: 'from-purple-500 to-purple-700', title: 'Ing. de Sistemas' },
              { name: 'Dennisse S. Sanchez A.',  initials: 'DS', color: 'from-pink-500 to-rose-600',     title: 'Ing. en Tecnologías de la Información' },
            ].map(member => (
              <div class="flex items-center gap-3">
                <div class={`flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-br ${member.color} flex items-center justify-center text-white text-xs font-bold shadow-sm`}>
                  {member.initials}
                </div>
                <div class="min-w-0">
                  <p class="text-white text-sm font-semibold leading-tight">{member.name}</p>
                  <p class="text-gray-400 text-xs leading-tight">{member.title}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
