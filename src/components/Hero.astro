---
import WhatsAppButton from './react/WhatsAppButton.tsx';
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden hero-grid pt-20"
  style="background: linear-gradient(135deg, #0a1628 0%, #0f2044 50%, #0a1628 100%);"
>
  <!-- Background decorative blobs -->
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-blue-600/20 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-green-500/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-800/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Text Content -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-blue-500/15 border border-blue-500/30 text-blue-300 text-sm font-medium px-4 py-2 rounded-full mb-6 animate-fade-in">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse-slow"></span>
          Soluciones Tecnológicas Empresariales
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.1] tracking-tight mb-6" style="animation: fadeUp 0.7s ease-out 0.1s both;">
          Tecnología confiable<br class="hidden sm:block"/>
          para entornos
          <span class="gradient-text block mt-2">empresariales exigentes</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-lg text-gray-300 leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0" style="animation: fadeUp 0.7s ease-out 0.3s both;">
          Optimizamos su infraestructura tecnológica con soluciones confiables, soporte especializado y equipos con garantía directa del fabricante.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start" style="animation: fadeUp 0.7s ease-out 0.5s both;">
          <WhatsAppButton variant="hero" label="Contáctanos por WhatsApp" client:load />
          <a
            href="#servicios"
            class="inline-flex items-center gap-2 text-gray-300 hover:text-white font-semibold text-base transition-colors duration-200 group"
          >
            Ver servicios
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 mt-12 pt-8 border-t border-white/10" style="animation: fadeUp 0.7s ease-out 0.7s both;">
          <div class="text-center lg:text-left">
            <div class="text-2xl sm:text-3xl font-black text-white">100%</div>
            <div class="text-xs text-gray-400 mt-1 leading-snug">Soporte garantizado</div>
          </div>
          <div class="text-center lg:text-left border-x border-white/8 px-4">
            <div class="text-2xl sm:text-3xl font-black text-white">24/7</div>
            <div class="text-xs text-gray-400 mt-1 leading-snug">Atención disponible</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-2xl sm:text-3xl font-black text-white">4+</div>
            <div class="text-xs text-gray-400 mt-1 leading-snug">Áreas de servicio</div>
          </div>
        </div>
      </div>

      <!-- Visual -->
      <div class="relative flex items-center justify-center" style="animation: fadeIn 1s ease-out 0.4s both;">
        <!-- Main card -->
        <div class="relative w-full max-w-md mx-auto">
          <!-- Glow ring -->
          <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-blue-500/30 to-green-500/20 blur-2xl scale-110"></div>

          <!-- Card -->
          <div class="relative bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl p-8 shadow-2xl">
            <!-- Network illustration -->
            <div class="relative">
              <!-- Central hub -->
              <div class="flex items-center justify-center mb-6">
                <div class="relative">
                  <div class="absolute inset-0 rounded-full bg-blue-500/30 blur-xl scale-150 animate-pulse-slow"></div>
                  <div class="relative w-20 h-20 rounded-full bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center shadow-xl shadow-blue-500/40">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
                    </svg>
                  </div>
                </div>
              </div>

              <!-- Service nodes grid -->
              <div class="grid grid-cols-2 gap-3">
                {[
                  { icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2h-2', label: 'Infraestructura', color: 'from-blue-500/20 to-blue-600/10', accent: 'text-blue-400' },
                  { icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z', label: 'Soporte Técnico', color: 'from-cyan-500/20 to-cyan-600/10', accent: 'text-cyan-400' },
                  { icon: 'M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0', label: 'Redes y WiFi', color: 'from-indigo-500/20 to-indigo-600/10', accent: 'text-indigo-400' },
                  { icon: 'M15 10l4.553-2.069A1 1 0 0121 8.868V15.13a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z', label: 'Seguridad CCTV', color: 'from-green-500/20 to-green-600/10', accent: 'text-green-400' },
                ].map(item => (
                  <div class={`bg-gradient-to-br ${item.color} border border-white/10 rounded-2xl p-4 flex flex-col items-center gap-2 hover:border-white/20 transition-all duration-300`}>
                    <svg class={`w-7 h-7 ${item.accent}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon}/>
                    </svg>
                    <span class="text-xs text-gray-300 font-medium text-center leading-tight">{item.label}</span>
                  </div>
                ))}
              </div>

              <!-- Status indicator -->
              <div class="mt-4 flex items-center justify-center gap-2 bg-green-500/10 border border-green-500/20 rounded-xl px-4 py-2">
                <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
                <span class="text-green-300 text-xs font-medium">Todos los servicios operativos</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce opacity-60">
    <span class="text-xs text-gray-400">Scroll</span>
    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
