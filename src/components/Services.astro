---
const services = [
  {
    id: 'infraestructura',
    title: 'Infraestructura Tecnológica',
    description: 'Equipamiento empresarial de alta calidad con garantía directa del fabricante.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>`,
    color: 'from-blue-600 to-blue-800',
    glow: 'shadow-blue-500/20',
    border: 'hover:border-blue-500/50',
    accent: 'text-blue-400',
    badge: 'bg-blue-500/10 border-blue-500/20 text-blue-300',
    items: [
      'Venta de computadoras, laptops y servidores',
      'Equipamiento tecnológico empresarial',
      'Periféricos y soluciones complementarias',
    ],
  },
  {
    id: 'soporte',
    title: 'Soporte Técnico Especializado',
    description: 'Diagnóstico preciso y solución ágil de fallas para mantener su operación activa.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`,
    color: 'from-cyan-600 to-cyan-800',
    glow: 'shadow-cyan-500/20',
    border: 'hover:border-cyan-500/50',
    accent: 'text-cyan-400',
    badge: 'bg-cyan-500/10 border-cyan-500/20 text-cyan-300',
    items: [
      'Mantenimiento preventivo y correctivo',
      'Diagnóstico y solución de fallas',
      'Soporte remoto y en sitio',
    ],
  },
  {
    id: 'redes',
    title: 'Redes y Telecomunicaciones',
    description: 'Conectividad empresarial robusta con soluciones WiFi avanzadas y cableado estructurado.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/>`,
    color: 'from-indigo-600 to-indigo-800',
    glow: 'shadow-indigo-500/20',
    border: 'hover:border-indigo-500/50',
    accent: 'text-indigo-400',
    badge: 'bg-indigo-500/10 border-indigo-500/20 text-indigo-300',
    items: [
      'Diseño e implementación de redes',
      'Cableado estructurado profesional',
      'Optimización de conectividad',
      'Evaluación de redes residenciales y empresariales',
      'Soluciones WiFi avanzadas (redes Mesh y repetidores)',
    ],
  },
  {
    id: 'seguridad',
    title: 'Seguridad Electrónica',
    description: 'Vigilancia continua y protección integral para sus instalaciones empresariales.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.868V15.13a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>`,
    color: 'from-green-600 to-green-800',
    glow: 'shadow-green-500/20',
    border: 'hover:border-green-500/50',
    accent: 'text-green-400',
    badge: 'bg-green-500/10 border-green-500/20 text-green-300',
    items: [
      'Instalación de sistemas CCTV',
      'Soluciones de videovigilancia',
      'Configuración y monitoreo continuo',
    ],
  },
];
---

<section id="servicios" class="py-24 lg:py-32 relative overflow-hidden" style="background: linear-gradient(180deg, #0a1628 0%, #0d1e3a 100%);">

  <!-- Background decoration -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-24 bg-gradient-to-b from-transparent to-blue-500/40"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-500/30 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="inline-block bg-blue-500/10 border border-blue-500/20 text-blue-300 text-sm font-semibold px-4 py-2 rounded-full mb-4">
        Nuestros Servicios
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-4 leading-tight">
        Soluciones integrales para
        <span class="gradient-text block mt-1">su empresa</span>
      </h2>
      <p class="text-gray-400 text-base sm:text-lg max-w-xl mx-auto leading-relaxed">
        Diseñamos e implementamos soluciones tecnológicas alineadas a las necesidades específicas de cada organización.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
      {services.map((service, index) => (
        <div
          class={`group relative bg-white/3 border border-white/8 ${service.border} rounded-2xl p-8 transition-all duration-400 hover:-translate-y-1 card-glow animate-on-scroll`}
          style={`transition-delay: ${index * 100}ms;`}
        >
          <!-- Card glow on hover -->
          <div class={`absolute inset-0 rounded-2xl bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-400`}
            style="background: radial-gradient(ellipse at top left, rgba(29,106,229,0.06), transparent 70%);">
          </div>

          <div class="relative">
            <!-- Icon + Title -->
            <div class="flex items-center gap-4 mb-3">
              <div class={`flex-shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br ${service.color} flex items-center justify-center shadow-lg ${service.glow}`}>
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={service.icon}></svg>
              </div>
              <h3 class="text-lg font-bold text-white leading-tight">{service.title}</h3>
            </div>
            <p class={`text-sm ${service.accent} font-medium leading-relaxed mb-6`}>{service.description}</p>

            <!-- Divider -->
            <div class="h-px bg-gradient-to-r from-white/10 to-transparent mb-5"></div>

            <!-- Items list -->
            <ul class="space-y-2.5">
              {service.items.map(item => (
                <li class="flex items-start gap-3 text-gray-300 text-sm leading-relaxed">
                  <span class={`flex-shrink-0 w-5 h-5 rounded-full ${service.badge} border flex items-center justify-center mt-0.5`}>
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <!-- CTA link -->
            <div class="mt-6 pt-4 border-t border-white/5">
              <a
                href={`https://wa.me/593960089996?text=Hola%2C%20estoy%20interesado%20en%20el%20servicio%20de%20${encodeURIComponent(service.title)}`}
                target="_blank"
                rel="noopener noreferrer"
                class={`inline-flex items-center gap-2 ${service.accent} hover:text-white text-sm font-semibold transition-colors duration-200 group/link`}
              >
                Consultar este servicio
                <svg class="w-4 h-4 transition-transform duration-200 group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
