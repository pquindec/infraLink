---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'InfraLink Networks — Tecnología confiable para entornos empresariales exigentes',
  description = 'InfraLink Networks: infraestructura tecnológica, soporte técnico, redes WiFi, cableado estructurado y seguridad CCTV para empresas en Ecuador. Contáctenos hoy.',
} = Astro.props;

const siteUrl = 'https://www.infralinknet.com';
const ogImage = `${siteUrl}/logo.png`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'InfraLink Networks',
  description: 'Soluciones tecnológicas empresariales: infraestructura, soporte técnico, redes, telecomunicaciones y seguridad electrónica.',
  url: siteUrl,
  telephone: '+593960089996',
  email: 'asespinoza97@outlook.com',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'EC',
  },
  sameAs: [],
  serviceType: [
    'Infraestructura tecnológica',
    'Soporte técnico especializado',
    'Redes y telecomunicaciones',
    'Seguridad electrónica CCTV',
    'Soluciones WiFi empresariales',
  ],
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'],
    opens: '08:00',
    closes: '18:00',
  },
  image: ogImage,
  priceRange: '$$',
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="infraestructura tecnológica Ecuador, soporte técnico empresas, redes WiFi empresarial, cableado estructurado, CCTV videovigilancia, InfraLink Networks" />
    <meta name="author" content="InfraLink Networks" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph (WhatsApp, Facebook, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1600" />
    <meta property="og:image:height" content="561" />
    <meta property="og:locale" content="es_EC" />
    <meta property="og:site_name" content="InfraLink Networks" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Datos estructurados para Google (LocalBusiness) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style>
      html {
        scroll-behavior: smooth;
      }
      * {
        box-sizing: border-box;
      }
      .animate-on-scroll {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.7s ease, transform 0.7s ease;
      }
      .animate-on-scroll.visible {
        opacity: 1;
        transform: translateY(0);
      }
      h1, h2, h3 {
        text-wrap: balance;
      }
      p {
        text-wrap: pretty;
      }
      .gradient-text {
        background: linear-gradient(135deg, #1d6ae5 0%, #22c55e 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .hero-grid {
        background-image:
          linear-gradient(rgba(29, 106, 229, 0.07) 1px, transparent 1px),
          linear-gradient(90deg, rgba(29, 106, 229, 0.07) 1px, transparent 1px);
        background-size: 50px 50px;
      }
      .card-glow:hover {
        box-shadow: 0 0 30px rgba(29, 106, 229, 0.25);
      }
      .card-glow-green:hover {
        box-shadow: 0 0 30px rgba(34, 197, 94, 0.2);
      }
    </style>
  </head>
  <body class="bg-brand-dark font-sans text-white antialiased">
    <slot />
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
